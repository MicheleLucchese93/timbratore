---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { PARTNER_APP_URL } from "../data/seo";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const benefits = [
  {
    title: t("partner.b1.title"),
    desc: t("partner.b1.desc"),
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
  {
    title: t("partner.b2.title"),
    desc: t("partner.b2.desc"),
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: t("partner.b3.title"),
    desc: t("partner.b3.desc"),
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0c1.1.128 1.907 1.077 1.907 2.185zM9.75 9h.008v.008H9.75V9zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 4.5h.008v.008h-.008V13.5zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>`,
  },
  {
    title: t("partner.b4.title"),
    desc: t("partner.b4.desc"),
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
];
---

<section id="partner" class="bg-white py-20 sm:py-28 scroll-mt-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-accent">
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        {t("partner.badge")}
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-on-surface sm:text-4xl">
        {t("partner.title")}
      </h2>
      <p class="mx-auto mt-4 max-w-3xl text-lg text-on-surface-variant">
        {t("partner.subtitle")}
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {benefits.map((b) => (
        <div class="rounded-2xl border border-gray-100 bg-surface p-6 transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <Fragment set:html={b.icon} />
          </div>
          <h3 class="mt-4 text-lg font-semibold text-on-surface">{b.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-on-surface-variant">{b.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-center gap-3">
      <a
        href="#contact"
        id="partner-cta"
        class="inline-flex items-center justify-center rounded-full bg-primary px-7 py-3 text-base font-semibold text-white hover:bg-primary-container transition-colors"
      >
        {t("partner.cta.join")}
      </a>
      <p class="text-sm text-on-surface-variant">
        {t("partner.cta.note")}{" "}
        <a
          href={PARTNER_APP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-primary hover:underline"
        >
          {t("partner.cta.login")}
        </a>
      </p>
    </div>
  </div>
</section>

<script>
  // Pre-fill the contact form so partner enquiries arrive labelled.
  function initPartnerCta() {
    const cta = document.getElementById("partner-cta");
    cta?.addEventListener("click", () => {
      const subject = document.querySelector<HTMLInputElement>(
        '#contact-form input[name="subject"]'
      );
      if (subject && !subject.value) {
        subject.value = "Richiesta partnership / rivendita sonoQui";
      }
    });
  }

  initPartnerCta();
  document.addEventListener("astro:page-load", initPartnerCta);
</script>
