---
// Public pricing section. Italian-only site, so copy is inline (same convention
// as Features.astro). Two flat plans, every feature included in both; the only
// difference is the user/sede ceiling. Monthly/annual billing toggle (annual =
// 11 months, i.e. one month free) is handled client-side by swapping the two
// price blocks rendered in each card. No-JS fallback shows the monthly price.
const plans = [
  {
    name: "Piccola",
    tagline: "Per team fino a 10 persone",
    monthly: "24,99",
    annualPerMonth: "22,91",
    annualTotal: "274,89",
    annualSave: "24,99",
    userLimit: "10",
    sediLimit: "3",
    recommended: true,
  },
  {
    name: "Media",
    tagline: "Per aziende fino a 20 persone",
    monthly: "39,99",
    annualPerMonth: "36,66",
    annualTotal: "439,89",
    annualSave: "39,99",
    userLimit: "20",
    sediLimit: "5",
    recommended: false,
  },
];

const included = [
  "Timbratura GPS al momento del tap",
  "Ferie, permessi e malattia",
  "Correzioni con audit log",
  "Anomalie orario segnalate in automatico",
  "Dashboard web per amministratori",
  "Export Excel per il commercialista",
  "Documenti e cedolini dei dipendenti",
  "Smart working e sedi multiple",
  "App iOS, Android e dashboard web",
];

const addons = [
  {
    title: "Dipendenti aggiuntivi",
    price: "1,99",
    per: "dipendente",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m9.75-4.13a4 4 0 10-5.5 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: "Sedi aggiuntive",
    price: "2,99",
    per: "sede",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3m4-8h2m-2 4h2m-2-8h2m4 8h2m-2-4h2m-2-4h2"/></svg>`,
  },
];

const check = `<svg class="mt-0.5 h-5 w-5 shrink-0 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
---

<section id="pricing" class="relative overflow-hidden bg-surface py-20 sm:py-28 scroll-mt-20">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -top-24 right-0 h-72 w-72 rounded-full bg-primary/5 blur-3xl"></div>
    <div class="absolute -bottom-24 left-0 h-72 w-72 rounded-full bg-secondary/5 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        Prezzi
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-on-surface sm:text-4xl">
        Prezzi chiari, tutto incluso
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-on-surface-variant">
        Ogni piano include <strong class="font-semibold text-on-surface">tutte le funzionalità</strong>. Nessun modulo a pagamento, nessun costo nascosto. Cambi piano quando cresci.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <div id="billing-toggle" role="group" aria-label="Periodo di fatturazione"
          class="inline-flex rounded-full border border-gray-200 bg-white p-1">
          <button type="button" data-billing="monthly" aria-pressed="true"
            class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white transition-colors">
            Mensile
          </button>
          <button type="button" data-billing="annual" aria-pressed="false"
            class="rounded-full px-5 py-2 text-sm font-semibold text-on-surface-variant transition-colors">
            Annuale
          </button>
        </div>
        <span class="inline-flex items-center gap-1 rounded-full bg-success-tint px-3 py-1 text-xs font-semibold text-success">
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/></svg>
          1 mese gratis con il piano annuale
        </span>
      </div>
    </div>

    <div class="mx-auto mt-12 grid max-w-4xl gap-6 lg:grid-cols-2">
      {plans.map((p) => (
        <div class={`relative flex flex-col rounded-3xl bg-white p-8 ${p.recommended ? "border-2 border-primary shadow-xl lg:scale-[1.02]" : "border border-gray-200 shadow-sm"}`}>
          {p.recommended && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-semibold uppercase tracking-wide text-white shadow">
              Consigliato
            </span>
          )}

          <h3 class="text-xl font-bold text-on-surface">{p.name}</h3>
          <p class="mt-1 text-sm text-on-surface-variant">{p.tagline}</p>

          <div class="mt-6 min-h-[5.5rem]">
            <div data-billing-view="monthly">
              <div class="flex items-baseline gap-1.5">
                <span class="text-5xl font-extrabold tracking-tight text-on-surface">{p.monthly}</span>
                <span class="text-xl font-bold text-on-surface">€</span>
                <span class="text-sm font-medium text-on-surface-variant">/mese</span>
              </div>
              <p class="mt-2 text-sm text-on-surface-variant">Fatturazione mensile</p>
            </div>
            <div data-billing-view="annual" class="hidden">
              <div class="flex items-baseline gap-1.5">
                <span class="text-5xl font-extrabold tracking-tight text-on-surface">{p.annualPerMonth}</span>
                <span class="text-xl font-bold text-on-surface">€</span>
                <span class="text-sm font-medium text-on-surface-variant">/mese</span>
              </div>
              <p class="mt-2 text-sm text-on-surface-variant">
                {p.annualTotal} €/anno · <span class="font-semibold text-success">risparmi {p.annualSave} €</span>
              </p>
            </div>
          </div>

          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-xl bg-surface p-3 text-center">
              <div class="text-xl font-bold text-primary">fino a {p.userLimit}</div>
              <div class="mt-0.5 text-xs text-on-surface-variant">dipendenti</div>
            </div>
            <div class="rounded-xl bg-surface p-3 text-center">
              <div class="text-xl font-bold text-primary">fino a {p.sediLimit}</div>
              <div class="mt-0.5 text-xs text-on-surface-variant">sedi</div>
            </div>
          </div>

          <a href="#contact"
            class={`mt-6 inline-flex items-center justify-center rounded-full px-6 py-3 text-base font-semibold transition-colors ${p.recommended ? "bg-primary text-white hover:bg-primary-container" : "border border-primary text-primary hover:bg-primary/5"}`}>
            Inizia ora
          </a>

          <div class="mt-8 border-t border-gray-100 pt-6">
            <p class="text-sm font-semibold text-on-surface">Tutte le funzionalità incluse</p>
            <ul class="mt-4 space-y-3">
              {included.map((f) => (
                <li class="flex items-start gap-2.5 text-sm text-on-surface-variant">
                  <Fragment set:html={check} />
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mx-auto mt-8 max-w-4xl rounded-3xl border border-gray-200 bg-white p-6 sm:p-8">
      <div class="text-center">
        <h3 class="text-lg font-semibold text-on-surface">Cresci oltre i limiti del piano</h3>
        <p class="mt-1 text-sm text-on-surface-variant">Aggiungi dipendenti e sedi singolarmente, quando ti servono.</p>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {addons.map((a) => (
          <div class="flex items-center gap-4 rounded-2xl bg-surface p-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-secondary/10 text-secondary">
              <Fragment set:html={a.icon} />
            </div>
            <div>
              <div class="text-sm font-semibold text-on-surface">{a.title}</div>
              <div class="mt-0.5 text-on-surface-variant">
                <span class="text-xl font-bold text-on-surface">+{a.price} €</span>
                <span class="text-sm"> / {a.per} / mese</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <p class="mx-auto mt-8 max-w-2xl text-center text-xs text-on-surface-variant">
      Prezzi IVA esclusa. L'app è gratuita da scaricare; l'attivazione del servizio avviene su richiesta.
    </p>
  </div>
</section>

<script>
  function initPricingToggle() {
    const toggle = document.getElementById("billing-toggle");
    if (!toggle) return;
    const buttons = toggle.querySelectorAll<HTMLButtonElement>("[data-billing]");

    function setBilling(mode: string) {
      buttons.forEach((b) => {
        const active = b.dataset.billing === mode;
        b.setAttribute("aria-pressed", String(active));
        b.classList.toggle("bg-primary", active);
        b.classList.toggle("text-white", active);
        b.classList.toggle("text-on-surface-variant", !active);
      });
      document.querySelectorAll<HTMLElement>("[data-billing-view]").forEach((el) => {
        el.classList.toggle("hidden", el.dataset.billingView !== mode);
      });
    }

    buttons.forEach((b) =>
      b.addEventListener("click", () => setBilling(b.dataset.billing || "monthly"))
    );
  }

  initPricingToggle();
  document.addEventListener("astro:page-load", initPricingToggle);
</script>
