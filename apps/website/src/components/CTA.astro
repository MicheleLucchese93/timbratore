---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { WEB_APP_URL, APP_STORE_URL, PLAY_STORE_URL } from "../data/seo";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="download" class="relative overflow-hidden bg-primary py-20 sm:py-28 scroll-mt-20">
  <div class="absolute inset-0">
    <div class="absolute top-0 right-0 h-64 w-64 rounded-full bg-white/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 h-48 w-48 rounded-full bg-white/5 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{t("cta.title")}</h2>
    <p class="mt-4 text-lg text-white/80">{t("cta.subtitle")}</p>

    <div class="mx-auto mt-10 grid max-w-xl grid-cols-1 gap-3 sm:grid-cols-3">
      <a href={APP_STORE_URL} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-3 py-2 text-on-surface hover:bg-gray-100 transition-colors"
        aria-label="Scarica su App Store">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <div class="text-left">
          <div class="text-[9px] leading-none opacity-60">Scarica su</div>
          <span class="text-sm font-semibold leading-tight">App Store</span>
        </div>
      </a>
      <a href={PLAY_STORE_URL} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-3 py-2 text-on-surface hover:bg-gray-100 transition-colors"
        aria-label="Scarica su Google Play">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814 13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893 2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.193 2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.198 12l2.5-2.486zM5.864 2.658 16.802 8.99l-2.302 2.302-8.636-8.634z"/>
        </svg>
        <div class="text-left">
          <div class="text-[9px] leading-none opacity-60">Scarica su</div>
          <span class="text-sm font-semibold leading-tight">Google Play</span>
        </div>
      </a>
      <a href={WEB_APP_URL} target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-3 py-2 text-on-surface hover:bg-gray-100 transition-colors"
        aria-label={t("hero.cta.web")}>
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
        <div class="text-left">
          <div class="text-[9px] leading-none opacity-60">Usa sul</div>
          <div class="text-sm font-semibold leading-tight">Web</div>
        </div>
      </a>
    </div>
  </div>
</section>
