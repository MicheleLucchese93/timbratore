---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const features = [
  {
    title: "Timbratura in un tap",
    desc: "Il dipendente timbra dal telefono. La posizione viene verificata solo nel momento del tap, mai durante il resto della giornata. Raggio della sede impostabile da 50 a 1500 metri.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: "Pensata per l'art. 4",
    desc: "Niente tracciamento continuo, niente riconoscimento facciale, nessun dato biometrico. Pensata per rispettare lo Statuto dei Lavoratori e il GDPR.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
  {
    title: "Ferie, permessi e malattia",
    desc: "I dipendenti inviano le richieste dal telefono. L'amministratore riceve una notifica e approva o rifiuta con un tocco. Saldo ferie sempre aggiornato.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "Documenti dei dipendenti",
    desc: "Condividi cedolini, CU, contratti e comunicazioni in PDF. Ogni dipendente vede solo i suoi; l'accesso all'archivio completo è riservato a un responsabile autorizzato, protetto da codice di verifica e con ogni accesso registrato. Presa visione tracciata e archiviazione automatica per 36 mesi. Sull'app la sezione è protetta da sblocco biometrico.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  },
  {
    title: "Bacheca aziendale",
    desc: "Pubblica comunicazioni e avvisi per tutti i dipendenti o solo per alcuni. Ognuno li legge dalla dashboard web e dall'app, con notifica via email e push, e conferma la lettura. Tu vedi in tempo reale quanti — e chi — hanno letto.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>`,
  },
  {
    title: "Correzioni sotto controllo",
    desc: "Ha dimenticato di timbrare? Il dipendente chiede la correzione, l'amministratore approva. Ogni modifica resta registrata: chi, quando e perché.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>`,
  },
  {
    title: "Anomalie segnalate",
    desc: "Turni troppo lunghi, pause anomale o timbrature mancanti vengono evidenziate in automatico. L'amministratore le rivede e le giustifica in pochi secondi.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: "Export per il commercialista",
    desc: "Un foglio Excel mensile pronto per le paghe italiane: ore totali, anomalie, ferie e permessi, divisi per dipendente e per sede.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  },
  {
    title: "Più sedi e smart working",
    desc: "Gestisci più sedi, ognuna con il proprio raggio. Per chi lavora da remoto puoi attivare lo smart working: si timbra senza verifica della posizione.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3m4-8h2m-2 4h2m-2-8h2m4 8h2m-2-4h2m-2-4h2"/></svg>`,
  },
  {
    title: "Ruoli e approvatori",
    desc: "Decidi chi può approvare. Puoi nominare approvatori dedicati per ogni sede, così ogni responsabile gestisce solo i propri dipendenti.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m9.75-4.13a4 4 0 10-5.5 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: "Dati protetti, in Europa",
    desc: "I dati della tua azienda sono cifrati, conservati su server nell'Unione Europea e isolati da quelli di ogni altra azienda. Restano tuoi: li esporti quando vuoi.",
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
  },
];
---

<section id="features" class="bg-white py-20 sm:py-28 scroll-mt-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-on-surface sm:text-4xl">{t("features.title")}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-on-surface-variant">{t("features.subtitle")}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-gray-100 bg-surface p-6 transition-shadow hover:shadow-md">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Fragment set:html={f.icon} />
          </div>
          <h3 class="mt-4 text-lg font-semibold text-on-surface">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-on-surface-variant">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
