---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Self-hosted on Cloudflare R2 (public bucket sonoqui-public, served from its
// r2.dev managed domain → cached at Cloudflare's edge). No third-party player,
// no cookies. Bump the ?v= when replacing the file so the edge serves the new cut.
const VIDEO_SRC =
  "https://pub-afe31975ed804122bb97af292e3a31cf.r2.dev/sonoqui-promo.mp4?v=1";
---

<section class="bg-white py-16 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
    <h2 class="text-3xl font-extrabold tracking-tight text-on-surface sm:text-4xl">
      {t("video.title")}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-on-surface-variant">
      {t("video.subtitle")}
    </p>

    <div id="video" class="mt-10 scroll-mt-2">
      <video
        controls
        playsinline
        preload="none"
        poster="/promo-thumbnail.jpg"
        aria-label={t("video.title")}
        class="block aspect-video w-full rounded-2xl bg-on-surface shadow-2xl ring-1 ring-black/5"
      >
        <source src={VIDEO_SRC} type="video/mp4" />
      </video>
    </div>
  </div>
</section>
