---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Labels are written to match the actual captured screen (see Specs/images/mobile).
const screenshots = [
  { file: "login", label: "Accesso sicuro", desc: "Email e password. L'account è creato dall'amministratore della tua azienda." },
  { file: "dashboard", label: "La tua giornata", desc: "Stato attuale, ore lavorate e conteggiate, sede. Timbra entrata, uscita e pause con un tap." },
  { file: "clock-in", label: "Storico timbrature", desc: "Totale lavorato su 7, 30 o 90 giorni. Ogni ingresso e uscita, giorno per giorno." },
  { file: "leaves-list", label: "Richiesta ferie", desc: "Scegli le date, tutto il giorno o a ore, e invia la richiesta all'amministratore." },
  { file: "leave-request", label: "Richiesta permesso", desc: "Permesso a orario specifico: imposta ora di inizio e fine e la motivazione." },
  { file: "corrections", label: "Segnalazione malattia", desc: "Comunica la malattia con numero di protocollo INPS e note facoltative." },
  { file: "correction-form", label: "Altre assenze", desc: "Donazione sangue, congedi e altri permessi, retribuiti o non retribuiti." },
  { file: "history-detail", label: "Le tue richieste", desc: "Stato di ferie e permessi: in attesa, approvate, annullate. Richiedi l'annullamento." },
  { file: "clock-in-success", label: "Correzioni da approvare", desc: "Per l'amministratore: timbrature mancanti segnalate dai dipendenti, da approvare o rifiutare." },
  { file: "history", label: "Tutte le correzioni", desc: "Storico completo delle correzioni con esito e motivazione." },
  { file: "notifications", label: "Approvazioni dal telefono", desc: "Per l'amministratore: approva richieste e annullamenti di ferie direttamente dall'app." },
  { file: "profile", label: "Centro notifiche", desc: "Esiti di approvazioni di ferie e correzioni in tempo reale." },
];

const src = (file: string) => `/screenshots/${file}.png`;
const webp = (file: string) => `/screenshots/${file}.webp`;

const groups: typeof screenshots[] = [];
for (let i = 0; i < screenshots.length; i += 3) {
  groups.push(screenshots.slice(i, i + 3));
}
---

<section id="screenshots" class="bg-surface py-20 sm:py-28 scroll-mt-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-on-surface sm:text-4xl">
        {t("screenshots.title")}
      </h2>
      <p class="mt-4 text-lg text-on-surface-variant">
        {t("screenshots.subtitle")}
      </p>
    </div>

    <div class="mt-16 sm:hidden">
      <div class="flex snap-x snap-mandatory overflow-x-auto gap-6 px-8 pb-4 -mx-4 scrollbar-hide" id="mobile-scroll">
        {screenshots.map((s, i) => (
          <div class="flex-shrink-0 w-[70vw] max-w-[220px] snap-center flex flex-col items-center text-center" data-mobile-item={i}>
            <button
              type="button"
              data-zoom
              data-src={src(s.file)}
              data-label={s.label}
              aria-label={`Ingrandisci: ${s.label}`}
              class="group relative block w-full cursor-zoom-in rounded-[1.8rem] transition-transform hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
            >
              <div class="rounded-[1.3rem] border-[4px] border-on-surface bg-on-surface p-0.5 shadow-xl">
                <picture>
                  <source srcset={webp(s.file)} type="image/webp" />
                  <img src={src(s.file)} alt={s.label} width="1206" height="2862" class="block w-full rounded-[1.1rem] bg-on-surface" loading="lazy" />
                </picture>
              </div>
              <span class="pointer-events-none absolute inset-0 flex items-center justify-center rounded-[1.8rem] bg-on-surface/0 opacity-0 transition-all duration-200 group-hover:bg-on-surface/20 group-hover:opacity-100">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white/90 text-on-surface shadow-lg">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6M19 11a8 8 0 11-16 0 8 8 0 0116 0z"/></svg>
                </span>
              </span>
            </button>
            <h3 class="mt-4 text-base font-semibold text-on-surface">{s.label}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-on-surface-variant">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 flex items-center justify-center gap-1.5" id="mobile-dots">
        {screenshots.map((_, i) => (
          <span
            class={`h-2 rounded-full transition-all duration-300 ${i === 0 ? "w-6 bg-primary" : "w-2 bg-gray-300"}`}
            data-mobile-dot={i}
          />
        ))}
      </div>
    </div>

    <div class="relative mt-16 hidden sm:block" id="screenshot-slider">
      <div class="overflow-hidden">
        <div id="slides-track" class="flex transition-transform duration-500 ease-in-out">
          {groups.map((group, gi) => (
            <div class="w-full flex-shrink-0" data-slide={gi}>
              <div class={`grid gap-8 justify-items-center ${group.length === 3 ? "grid-cols-3" : group.length === 2 ? "grid-cols-2 max-w-3xl mx-auto" : "grid-cols-1 max-w-xs mx-auto"}`}>
                {group.map((s) => (
                  <div class="flex flex-col items-center text-center max-w-[200px]">
                    <button
                      type="button"
                      data-zoom
                      data-src={src(s.file)}
                      data-label={s.label}
                      aria-label={`Ingrandisci: ${s.label}`}
                      class="group relative block w-full cursor-zoom-in rounded-[1.8rem] transition-transform hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                    >
                      <div class="rounded-[1.3rem] border-[4px] border-on-surface bg-on-surface p-0.5 shadow-xl">
                      <picture>
                        <source srcset={webp(s.file)} type="image/webp" />
                        <img src={src(s.file)} alt={s.label} width="1206" height="2862" class="block w-full rounded-[1.1rem] bg-on-surface" loading="lazy" />
                      </picture>
                      </div>
                      <span class="pointer-events-none absolute inset-0 flex items-center justify-center rounded-[1.8rem] bg-on-surface/0 opacity-0 transition-all duration-200 group-hover:bg-on-surface/20 group-hover:opacity-100">
                        <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white/90 text-on-surface shadow-lg">
                          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 8v6M8 11h6M19 11a8 8 0 11-16 0 8 8 0 0116 0z"/></svg>
                        </span>
                      </span>
                    </button>
                    <h3 class="mt-4 text-base font-semibold text-on-surface">{s.label}</h3>
                    <p class="mt-1.5 text-sm leading-relaxed text-on-surface-variant">{s.desc}</p>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <button
        id="slider-prev"
        class="absolute left-0 top-1/3 -translate-x-2 -translate-y-1/2 flex h-11 w-11 items-center justify-center rounded-full bg-white shadow-lg ring-1 ring-gray-200 hover:bg-gray-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
        aria-label="Precedente"
      >
        <svg class="h-5 w-5 text-on-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button
        id="slider-next"
        class="absolute right-0 top-1/3 translate-x-2 -translate-y-1/2 flex h-11 w-11 items-center justify-center rounded-full bg-white shadow-lg ring-1 ring-gray-200 hover:bg-gray-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
        aria-label="Successivo"
      >
        <svg class="h-5 w-5 text-on-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>

      <div class="mt-10 flex items-center justify-center gap-2" id="slider-dots">
        {groups.map((_, i) => (
          <button
            class={`h-2.5 rounded-full transition-all duration-300 ${i === 0 ? "w-8 bg-primary" : "w-2.5 bg-gray-300 hover:bg-gray-400"}`}
            data-dot={i}
            aria-label={`Slide ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>

  <div
    id="mobile-lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-on-surface/80 p-4 backdrop-blur-sm sm:p-8"
    role="dialog"
    aria-modal="true"
    aria-label="Anteprima schermata"
  >
    <button
      type="button"
      id="mobile-lightbox-close"
      class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-on-surface shadow-lg transition-colors hover:bg-white"
      aria-label="Chiudi anteprima"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <figure class="flex max-h-full flex-col items-center">
      <div class="rounded-[2.2rem] border-[6px] border-on-surface bg-on-surface p-0.5 shadow-2xl">
        <img id="mobile-lightbox-img" src="" alt="" class="block max-h-[80vh] w-auto rounded-[1.9rem]" />
      </div>
      <figcaption id="mobile-lightbox-cap" class="mt-4 text-center text-sm font-semibold text-white"></figcaption>
    </figure>
  </div>
</section>

<style>
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
</style>

<script>
  function initMobileScroll() {
    const container = document.getElementById("mobile-scroll");
    const dotsContainer = document.getElementById("mobile-dots");
    if (!container || !dotsContainer) return;
    const dots = dotsContainer.querySelectorAll<HTMLSpanElement>("[data-mobile-dot]");
    const items = container.querySelectorAll<HTMLElement>("[data-mobile-item]");
    if (!items.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const idx = Number((entry.target as HTMLElement).dataset.mobileItem);
            dots.forEach((dot, i) => {
              dot.className = i === idx
                ? "h-2 w-6 rounded-full bg-primary transition-all duration-300"
                : "h-2 w-2 rounded-full bg-gray-300 transition-all duration-300";
            });
          }
        });
      },
      { root: container, threshold: 0.6 }
    );
    items.forEach((item) => observer.observe(item));
  }

  function initSlider() {
    const track = document.getElementById("slides-track");
    const prevBtn = document.getElementById("slider-prev");
    const nextBtn = document.getElementById("slider-next");
    const dotsContainer = document.getElementById("slider-dots");
    if (!track || !prevBtn || !nextBtn || !dotsContainer) return;
    const dots = dotsContainer.querySelectorAll<HTMLButtonElement>("[data-dot]");
    const totalSlides = dots.length;
    let current = 0;

    function goTo(index: number) {
      if (index < 0 || index >= totalSlides) return;
      current = index;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => {
        dot.className = i === current
          ? "h-2.5 w-8 rounded-full bg-primary transition-all duration-300"
          : "h-2.5 w-2.5 rounded-full bg-gray-300 hover:bg-gray-400 transition-all duration-300";
      });
      (prevBtn as HTMLButtonElement).disabled = current === 0;
      (nextBtn as HTMLButtonElement).disabled = current === totalSlides - 1;
    }

    prevBtn.addEventListener("click", () => goTo(current - 1));
    nextBtn.addEventListener("click", () => goTo(current + 1));
    dots.forEach((dot) => {
      dot.addEventListener("click", () => goTo(Number(dot.getAttribute("data-dot"))));
    });

    let startX = 0;
    let isDragging = false;
    track.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; isDragging = true; });
    track.addEventListener("touchend", (e) => {
      if (!isDragging) return;
      isDragging = false;
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
    });

    goTo(0);
  }

  function closeMobileLightbox() {
    const box = document.getElementById("mobile-lightbox");
    const img = document.getElementById("mobile-lightbox-img") as HTMLImageElement | null;
    if (!box) return;
    box.classList.add("hidden");
    box.classList.remove("flex");
    if (img) img.src = "";
    document.body.style.overflow = "";
  }

  function initMobileLightbox() {
    const box = document.getElementById("mobile-lightbox");
    const img = document.getElementById("mobile-lightbox-img") as HTMLImageElement | null;
    const cap = document.getElementById("mobile-lightbox-cap");
    const closeBtn = document.getElementById("mobile-lightbox-close");
    if (!box || !img || !cap || !closeBtn) return;

    document.querySelectorAll<HTMLButtonElement>("#screenshots [data-zoom]").forEach((btn) => {
      btn.addEventListener("click", () => {
        img.src = btn.dataset.src || "";
        img.alt = btn.dataset.label || "";
        cap.textContent = btn.dataset.label || "";
        box.classList.remove("hidden");
        box.classList.add("flex");
        document.body.style.overflow = "hidden";
        (closeBtn as HTMLButtonElement).focus();
      });
    });

    closeBtn.addEventListener("click", closeMobileLightbox);
    box.addEventListener("click", (e) => {
      if (e.target === box) closeMobileLightbox();
    });
  }

  // Bound once at module load so it survives view-transition swaps without leaking.
  document.addEventListener("keydown", (e) => {
    const box = document.getElementById("mobile-lightbox");
    if (e.key === "Escape" && box && !box.classList.contains("hidden")) closeMobileLightbox();
  });

  initSlider();
  initMobileScroll();
  initMobileLightbox();
  document.addEventListener("astro:page-load", () => { initSlider(); initMobileScroll(); initMobileLightbox(); });
</script>
