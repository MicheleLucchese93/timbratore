---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { CONTACT_EMAIL, LINKEDIN_URL } from "../data/seo";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const privacyPath = `/${lang}/privacy-policy/`;
const cookiePath = `/${lang}/cookie-policy/`;
const termsPath = `/${lang}/termini-e-condizioni/`;
const eulaPath = `/${lang}/eula/`;
---

<footer id="contact" class="border-t border-gray-100 bg-surface py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto mb-12 max-w-4xl text-center">
      <h3 class="text-3xl font-bold text-on-surface sm:text-4xl">{t("contact.title")}</h3>
      <p class="mt-3 mb-8 text-lg text-on-surface-variant">{t("contact.subtitle")}</p>
      <p class="text-lg text-primary font-semibold">
        <a href={`mailto:${CONTACT_EMAIL}`} class="hover:underline">{CONTACT_EMAIL}</a>
      </p>
      <p class="mt-2 text-sm text-on-surface-variant">Rispondiamo entro 24 ore lavorative.</p>
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 border-t border-gray-200 pt-8">
      <div>
        <div class="flex items-center gap-2">
          <img src="/icon.png" alt="sonoQui" class="h-8 w-8 rounded-lg" />
          <span class="text-lg font-bold text-primary">sono<span class="text-accent">Qui</span></span>
        </div>
        <p class="mt-3 text-sm text-on-surface-variant">
          Rilevazione presenze per le piccole aziende italiane.
        </p>
      </div>

      <div>
        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wide text-on-surface-variant">Prodotto</h4>
        <ul class="space-y-2">
          <li><a href={`/${lang}/#screenshots`} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("nav.screenshots")}</a></li>
          <li><a href={`/${lang}/#web`} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("nav.web")}</a></li>
          <li><a href={`/${lang}/#faq`} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("nav.faq")}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wide text-on-surface-variant">Legale</h4>
        <ul class="space-y-2">
          <li><a href={privacyPath} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("footer.privacy")}</a></li>
          <li><a href={cookiePath} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("footer.cookies")}</a></li>
          <li><a href={termsPath} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("footer.terms")}</a></li>
          <li><a href={eulaPath} class="text-sm text-on-surface-variant hover:text-primary transition-colors">{t("footer.eula")}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-3 text-sm font-semibold uppercase tracking-wide text-on-surface-variant">Michele Lucchese</h4>
        <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm text-on-surface-variant hover:text-primary transition-colors">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-on-surface-variant">
      &copy; {new Date().getFullYear()} sonoQui. {t("footer.rights")}
    </div>
  </div>
</footer>
