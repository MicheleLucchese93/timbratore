---
import BaseLayout from "./BaseLayout.astro";
import type { Lang } from "../i18n/ui";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { SITE_URL } from "../data/seo";

interface Props {
  title: string;
  description?: string;
  lastUpdated: string;
  /** ISO 8601 date (e.g. "2026-06-16") for the WebPage dateModified signal. */
  isoDate?: string;
  alternatePaths?: Partial<Record<Lang, string>>;
}

const { title, description, lastUpdated, isoDate, alternatePaths } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pageUrl = alternatePaths?.[lang] ? `${SITE_URL}${alternatePaths[lang]}` : undefined;
const schema = isoDate
  ? {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `${title} — sonoQui`,
      ...(pageUrl ? { url: pageUrl } : {}),
      inLanguage: "it-IT",
      dateModified: isoDate,
      publisher: { "@type": "Organization", name: "sonoQui", url: SITE_URL },
    }
  : undefined;
---

<BaseLayout title={`${title} — sonoQui`} description={description} type="article" alternatePaths={alternatePaths} schema={schema}>
  <div class="pt-24 pb-16 bg-surface">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold text-primary sm:text-4xl">{title}</h1>
      <p class="mt-2 text-sm text-on-surface-variant">
        {t("legal.lastUpdated")}: {lastUpdated}
      </p>
    </div>
  </div>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <article class="prose prose-gray max-w-none
      [&_h2]:text-primary [&_h2]:text-xl [&_h2]:font-bold [&_h2]:mt-10 [&_h2]:mb-4
      [&_h3]:text-on-surface [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:mt-6 [&_h3]:mb-3
      [&_p]:text-on-surface-variant [&_p]:leading-relaxed [&_p]:mb-4
      [&_ul]:text-on-surface-variant [&_ul]:space-y-2 [&_ul]:mb-4 [&_ul]:ml-5 [&_ul]:list-disc
      [&_li]:leading-relaxed
      [&_strong]:text-on-surface
      [&_a]:text-primary [&_a]:underline hover:[&_a]:text-primary-container
      [&_.highlight-box]:bg-surface [&_.highlight-box]:border [&_.highlight-box]:border-gray-200 [&_.highlight-box]:border-l-4 [&_.highlight-box]:border-l-primary [&_.highlight-box]:rounded-lg [&_.highlight-box]:p-4 [&_.highlight-box]:my-6
      [&_.highlight-box_p]:text-primary [&_.highlight-box_p]:text-sm [&_.highlight-box_p]:mb-0
      [&_.contact-box]:bg-surface [&_.contact-box]:border [&_.contact-box]:border-gray-200 [&_.contact-box]:rounded-lg [&_.contact-box]:p-5 [&_.contact-box]:mt-10
      [&_.contact-box_h3]:text-primary [&_.contact-box_h3]:mt-0
      [&_.contact-box_p]:text-primary [&_.contact-box_p]:mb-2
    ">
      <slot />
    </article>
  </div>
</BaseLayout>
