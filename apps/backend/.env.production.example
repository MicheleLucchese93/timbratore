# Production env for cisono-api. Real values live ONLY on the server at
# /opt/cisono/apps/backend/.env.production — never committed to git.

NODE_ENV=production
PORT=4000

# Postgres lives in /opt/infra. cisono-api joins infra_internal and reaches
# it via the docker DNS hostname `postgres`. Use the `app` role (single
# non-superuser role per xdevapp-infra pg-init).
DATABASE_URL=postgres://app:REPLACE_APP_PG_PASS@postgres:5432/cisono
# Superuser-equivalent for migrations / system queries / scripts.
# `cisono_owner` is created by pg-init/02-create-cisono-db.sql below — give
# the same password as POSTGRES_PASSWORD on the infra stack.
ADMIN_DATABASE_URL=postgres://cisono_owner:REPLACE_OWNER_PG_PASS@postgres:5432/cisono

# Must match the value gotrue-cisono mints (docker-compose.yml).
GOTRUE_JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
GOTRUE_JWT_ISSUER=https://auth-cisono.xdevapp.it
GOTRUE_URL=https://auth-cisono.xdevapp.it
GOTRUE_SERVICE_ROLE_KEY=REPLACE_WITH_gotrue_service_role_jwt

CORS_ORIGINS=https://app-cisono.xdevapp.it
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
BACKEND_URL=https://api-cisono.xdevapp.it
WEB_PUBLIC_URL=https://app-cisono.xdevapp.it
SCHEDULER_ENABLED=true
CRON_SECRET=REPLACE_WITH_openssl_rand_hex_32
TRUSTED_PROXY_HOPS=1

# Hard-off in production. Mints HS256 tokens — only for local dev.
DEV_AUTH_ENABLED=false

STORAGE_DRIVER=disk
STORAGE_DISK_PATH=/data/exports
NOMINATIM_USER_AGENT=ciSono/0.1 (productdevelopment@archivagroup.it)

# Centrifugo proxy secret — must equal CENTRIFUGO_CISONO_API_KEY in /opt/cisono/.env
CENTRIFUGO_API_URL=http://centrifugo-cisono:8000/api
CENTRIFUGO_API_KEY=REPLACE_SAME_AS_CENTRIFUGO_CISONO_API_KEY
CENTRIFUGO_PROXY_SECRET=REPLACE_SAME_AS_CENTRIFUGO_CISONO_API_KEY
