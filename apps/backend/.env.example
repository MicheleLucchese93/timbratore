NODE_ENV=development
PORT=4000
# Application connection — non-superuser, respects RLS.
DATABASE_URL=postgres://cisono_app:devpw@localhost:5432/cisono_dev
# Owner/superuser — used only for migrations, scripts, scheduler, auth lookup.
ADMIN_DATABASE_URL=postgres://localadmin@localhost:5432/cisono_dev

# Generate with: openssl rand -hex 32
GOTRUE_JWT_SECRET=replace_me_with_a_real_secret_at_least_thirty_two_chars
GOTRUE_JWT_ISSUER=https://auth.cisono.local
GOTRUE_URL=https://auth.cisono.local
GOTRUE_SERVICE_ROLE_KEY=replace_me

CORS_ORIGINS=http://localhost:5173,http://localhost:4000,http://localhost:8082
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000
BACKEND_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:5173
SCHEDULER_ENABLED=false
CRON_SECRET=replace_with_random_value
TRUSTED_PROXY_HOPS=0

# Local dev only — emits HS256 JWTs without GoTrue. Must be false in prod.
DEV_AUTH_ENABLED=true

STORAGE_DRIVER=disk
STORAGE_DISK_PATH=./storage
NOMINATIM_USER_AGENT=ciSono-dev/0.1 (productdevelopment@archivagroup.it)

# Google Maps Places API key (server-side proxy). Optional in dev; required for
# branch address search. Restrict by IP / referrer in Google Cloud console.
GOOGLE_MAPS_API_KEY=
