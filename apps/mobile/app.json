{
  "expo": {
    "name": "sonoQui",
    "slug": "traduttore",
    "version": "7.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sonoqui",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "app.cisono.cisono",
      "buildNumber": "2",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "sonoQui usa la posizione SOLO al momento della timbratura per verificare che tu sia presso la sede di lavoro. La posizione NON viene mai tracciata in background. sonoQui uses your location ONLY at clock-in to verify you are at the work site. Location is NEVER tracked in the background.",
        "NSMotionUsageDescription": "sonoQui può usare i sensori di movimento solo per migliorare la precisione della posizione al momento della timbratura. Nessun dato di movimento viene tracciato in background. sonoQui may use motion sensors only to improve location accuracy at clock-in. No motion data is tracked in the background.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "app.sonoqui.mobile",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "blockedPermissions": [
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#fffbf8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0369a1"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "sonoQui usa la posizione SOLO al momento della timbratura."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fffbf8",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "./plugins/withInstallGroupFix"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "729f39a2-86a4-4bb6-ae03-21dad1922c34"
      },
      "apiBaseUrl": "https://api-sonoqui.xdevapp.it",
      "authBaseUrl": "https://auth-sonoqui.xdevapp.it"
    },
    "owner": "micheel93-2"
  }
}
