# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
android/keystore.properties
scripts/app-release.aab
scripts/app-release.apks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem
# …except the PUBLIC OTA code-signing cert: it is referenced by
# app.json > updates.codeSigningCertificate and bundled into the binary, so it
# must be committed. The private + public keys stay ignored — they live only on
# the OTA server under /opt/sonoqui/ota/keys/.
!credentials/certificate.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# native folders committed (Bare workflow). Build artifacts ignored via
# their own .gitignore files inside ios/ and android/.
