# Mobile env vars. Real values live in `.env.local` (gitignored).
# Loaded by Expo CLI / Metro and inlined into bundle at build time via the
# `EXPO_PUBLIC_` prefix. LoginScreen autofills these credentials only when the
# app runs in Expo Go (Constants.appOwnership === 'expo') AND __DEV__ is true,
# so they cannot prefill in production builds even if accidentally bundled.

EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=
