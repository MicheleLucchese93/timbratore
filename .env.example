# Root env consumed by docker-compose.yml. Real values on server at
# /opt/cisono/.env (NOT in git). Generate secrets with `openssl rand -hex 32`.

POSTGRES_PASSWORD=REPLACE_FROM_OPT_INFRA_DOT_ENV
APP_PG_PASS=REPLACE_FROM_OPT_INFRA_DOT_ENV
GOTRUE_PG_PASS=REPLACE_FROM_OPT_INFRA_DOT_ENV

CISONO_JWT_SECRET=REPLACE_WITH_HEX_32
CENTRIFUGO_CISONO_HMAC_SECRET=REPLACE_WITH_HEX_32
CENTRIFUGO_CISONO_API_KEY=REPLACE_WITH_HEX_32

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=REPLACE
SMTP_PASS=REPLACE

# Optional OAuth providers — leave blank to disable until Apple/Google ready.
CISONO_GOOGLE_ENABLED=false
CISONO_GOOGLE_CLIENT_ID=
CISONO_GOOGLE_SECRET=
CISONO_APPLE_ENABLED=false
CISONO_APPLE_CLIENT_ID=app.cisono.cisono.auth,app.cisono.cisono
CISONO_APPLE_SECRET=

# Google Maps JS API key — baked into cisono-web at build time. Restrict by HTTP
# referrer to https://app-cisono.xdevapp.it/* in Google Cloud console.
VITE_GOOGLE_MAPS_API_KEY=
